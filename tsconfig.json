{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noImplicitAny": false,
    //    "noImplicitReturns": true,
    "noImplicitThis": false,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": false,
    "outDir": "lib",
    "rootDir": "src",
    "skipLibCheck": true,
    // "suppressImplicitAnyIndexErrors": true,  // Not possible any more with TypeScript 5.8
    "sourceMap": true,
    "target": "ES6",
    "types": ["node"]
  },
  "files": [
    "./src/api.ts",
    "./src/fetch.ts",
    "./src/index.ts",
    "./src/nag.ts",
    "./src/pgn.ts",
    "./src/sb.ts",
    "./src/state.ts",
    "./src/types.ts"
  ]
}
